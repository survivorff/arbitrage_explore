# 机会雷达引擎 · 环境配置模板
# 复制为 .env 并填入真实值。.env 已被 .gitignore 排除，绝不入库。

# ---- AI 辅助（初筛打标 / 起草，使用 OpenAI 兼容接口）----
# 任何兼容 OpenAI Chat Completions 的服务都可用（官方、中转站、本地等）
RADAR_AI_ENABLED=false
RADAR_AI_BASE_URL=https://api.openai.com/v1
RADAR_AI_API_KEY=sk-your-key-here
RADAR_AI_MODEL=gpt-4o-mini
# 初筛用便宜模型即可；起草可换更强模型

# ---- 数据库 ----
RADAR_DB_PATH=radar.db

# ---- 采集 ----
# 单次采集每个源最多保留多少条新条目
RADAR_FETCH_LIMIT=50
# HTTP 超时（秒）
RADAR_HTTP_TIMEOUT=20
# User-Agent（礼貌抓取）
RADAR_USER_AGENT=opportunity-radar/0.1 (personal research)

# ---- 赛道（当前聚焦）----
RADAR_TRACK=AI工具

# ---- Telegram 推送（分发渠道，可选）----
# 找 @BotFather 创建 bot 拿 token；把 bot 加为频道管理员
RADAR_TG_ENABLED=false
RADAR_TG_BOT_TOKEN=
# 全局默认（私聊调试用，自动推送不会用它，避免误推）
RADAR_TG_CHAT_ID=
# 一个频道一个赛道（推荐）：RADAR_TG_CHAT_<赛道key大写>
RADAR_TG_CHAT_CRYPTO=@your_crypto_channel
RADAR_TG_CHAT_AI=@your_ai_channel
RADAR_TG_CHAT_DEV=@your_dev_channel
